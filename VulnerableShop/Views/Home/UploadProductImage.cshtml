@{
    ViewData["Title"] = "Ürün Resmi Yükle & Tetikle";
}

<div class="row">
    <div class="col-md-6">
        <div class="main-card">
            <h2 class="section-title">Yeni Dosya Yükle</h2>
            <form asp-action="UploadProductImage" method="post" enctype="multipart/form-data" class="mb-4">
                <div class="mb-3">
                    <input type="file" name="file" class="form-control" />
                </div>
                <button type="submit" class="btn btn-soft w-100">Yükle</button>
            </form>

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success">@TempData["Message"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger" style="font-size: 0.9rem;">@TempData["Error"]</div>
            }
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-warning">@ViewBag.Error</div>
            }
        </div>
    </div>

    <div class="col-md-6">
        <div class="main-card">
            <h2 class="section-title">Yüklenen Dosyaları Tetikle (RCE)</h2>
            <p class="text-muted mb-3">Yüklediğiniz dosyaların IIS (w3wp.exe) altında tetiklenmesini sağlayabilirsiniz.</p>

            <div class="list-group">
                @if (ViewBag.UploadedFiles != null)
                {
                    @foreach (var file in (List<string>)ViewBag.UploadedFiles)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            @file
                            <div class="btn-group">
                                <a asp-action="TriggerFile" asp-route-fileName="@file" class="btn btn-sm btn-danger">🚀 Tetikle</a>
                                <a href="/uploads/@file" target="_blank" class="btn btn-sm btn-outline-primary">🌐 Web Erişimi</a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">Henüz dosya yüklenmemiş veya dizin boş.</p>
                }
            </div>

            <div class="alert alert-info mt-3" style="font-size: 0.85rem;">
                <strong>İpucu:</strong> Eğer 500 hatası alıyorsanız, IIS üzerinde <code>C:\inetpub\vulnerableshop\wwwroot\uploads</code> klasörüne <code>IIS AppPool\<SiteAdi></code> kullanıcısı için <strong>Yazma (Write)</strong> yetkisi verdiğinizden emin olun.
            </div>
        </div>
    </div>
</div>
